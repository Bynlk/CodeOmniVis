    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "fast-glob": "^3.3.0",
    "open": "^10.0.0",
    "ora": "^8.0.0",
    "sql.js": "^1.10.0",
    "tree-sitter-wasms": "^0.1.13",
