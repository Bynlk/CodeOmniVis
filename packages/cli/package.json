{
  "name": "@bynlk/codeomnivis",
  "version": "0.0.1",
  "description": "Zero-config TypeScript full-stack architecture visualizer with a local workbench and MCP server for AI coding agents",
  "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bynlk/CodeOmniVis.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Bynlk/CodeOmniVis#readme",
  "bugs": {
    "url": "https://github.com/Bynlk/CodeOmniVis/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "codeomnivis",
    "typescript",
    "architecture-visualization",
    "full-stack",
    "dependency-graph",
    "nextjs",
    "react",
    "prisma",
    "mcp",
    "ai-coding-agent",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "codeomnivis": "./bin/codeomnivis.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@prisma/internals": "^5.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "fast-glob": "^3.3.0",
    "open": "^10.0.0",
    "ora": "^8.0.0",
    "sql.js": "^1.10.0",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^21.0.0",
    "typescript": "^5.5.0",
    "web-tree-sitter": "^0.20.8",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@codeomnivis/analyzer": "workspace:*",
    "@codeomnivis/mcp": "workspace:*",
    "@codeomnivis/server": "workspace:*",
    "@codeomnivis/shared": "workspace:*",
    "@codeomnivis/ui": "workspace:*",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
