{
  "name": "@omnivis/server",
  "version": "0.0.1",
  "private": true,
  "description": "Web server for OmniVis visualization",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omnivis/shared": "workspace:*",
    "@omnivis/analyzer": "workspace:*",
    "express": "^4.18.0",
    "ws": "^8.16.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",
    "@types/cors": "^2.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
