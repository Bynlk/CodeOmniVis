{
  "name": "@codeomnivis/server",
  "version": "0.0.1",
  "description": "Web server for CodeOmniVis visualization",
  "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bynlk/CodeOmniVis.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/Bynlk/CodeOmniVis#readme",
  "keywords": ["codeomnivis", "architecture", "visualization", "server"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codeomnivis/analyzer": "workspace:*",
    "@codeomnivis/shared": "workspace:*",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "rimraf": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
