{
  "name": "@codeomnivis/mcp",
  "version": "0.0.1",
  "description": "MCP Server for CodeOmniVis",
  "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bynlk/CodeOmniVis.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/Bynlk/CodeOmniVis#readme",
  "keywords": ["codeomnivis", "architecture", "visualization", "mcp"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@codeomnivis/analyzer": "workspace:*",
    "@codeomnivis/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
