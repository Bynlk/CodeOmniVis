{
  "name": "@codeomnivis/analyzer",
  "version": "0.0.1",
  "description": "Code analysis engine for CodeOmniVis",
  "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bynlk/CodeOmniVis.git",
    "directory": "packages/analyzer"
  },
  "homepage": "https://github.com/Bynlk/CodeOmniVis#readme",
  "keywords": [
    "codeomnivis",
    "architecture",
    "visualization",
    "typescript",
    "parser"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external ts-morph --external typescript --external @prisma/internals",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@codeomnivis/shared": "workspace:*",
    "@prisma/internals": "^5.0.0",
    "fast-glob": "^3.3.0",
    "sql.js": "^1.10.0",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^21.0.0",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
